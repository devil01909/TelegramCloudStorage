<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark theme -->
    <style name="Theme.TelegramCloudStorage" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (dark mode) -->
        <item name="colorPrimary">#0088cc</item>
        <item name="colorPrimaryVariant">#006699</item>
        <item name="colorOnPrimary">#ffffff</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">#34a853</item>
        <item name="colorSecondaryVariant">#2c8c45</item>
        <item name="colorOnSecondary">#ffffff</item>
        
        <!-- Background colors (dark mode) -->
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1e1e1e</item>
        <item name="colorOnSurface">#e1e1e1</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">#1a1a1a</item>
        <item name="android:windowBackground">@color/background_dark</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">#ffffff</item>
        <item name="android:textColorSecondary">#b0b0b0</item>
        
        <!-- Material 3 specific -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>
        
        <!-- Bottom sheet theme -->
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.Material3.BottomSheetDialog</item>
    </style>
    
    <!-- Dialog theme for dark mode -->
    <style name="Theme.TelegramCloudStorage.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:colorBackground">#1e1e1e</item>
    </style>
    
    <!-- Bottom sheet theme for dark mode -->
    <style name="Theme.TelegramCloudStorage.BottomSheet" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/accent</item>
    </style>
</resources>