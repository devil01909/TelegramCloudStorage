<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TelegramCloudStorage" parent="Theme.Material3.DayNight.NoActionBar">
        
        <item name="colorPrimary">#0088cc</item>
        <item name="colorPrimaryVariant">#006699</item>
        <item name="colorOnPrimary">#ffffff</item>
        
        
        <item name="colorSecondary">#34a853</item>
