<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/navigation_files">

    <fragment
        android:id="@+id/navigation_files"
        android:name="com.yourname.telegramcloud.ui.files.FileListFragment"
        android:label="Files" />

    <fragment
        android:id="@+id/navigation_recent"
        android:name="com.yourname.telegramcloud.ui.files.FileListFragment"
        android:label="Recent" />

    <fragment
        android:id="@+id/navigation_favorites"
        android:name="com.yourname.telegramcloud.ui.files.FileListFragment"
        android:label="Favorites" />

    <activity
        android:id="@+id/navigation_settings"
        android:name="com.yourname.telegramcloud.ui.settings.SettingsActivity"
        android:label="Settings" />

</navigation>